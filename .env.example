PORT=5173

# Postgres connection string (phải khớp với pgAdmin):
# postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Lưu ý: Nếu pgAdmin hiển thị "Test_2/postgres" → database thường là "postgres"
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Optional: limit points returned
POINTS_LIMIT=500

# 5 bảng geometry UNION (road, garbadge, bounds, instruction-generated, building)
GEOMETRY_LAYERS=road,garbadge,bounds,instruction-generated,building

